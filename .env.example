# Credenciais de Staging
STAGING_OPERATOR_EMAIL=
STAGING_OPERATOR_PASSWORD=
STAGING_MANAGER_EMAIL=
STAGING_MANAGER_PASSWORD=

# Segundo operador de staging (Operador + Supervisor + Gestor) — usado como observador em cenários de presença
STAGING_OBSERVER_EMAIL=
STAGING_OBSERVER_PASSWORD=

# Credenciais de Canary
CANARY_OPERATOR_EMAIL=
CANARY_OPERATOR_PASSWORD=
CANARY_MANAGER_EMAIL=
CANARY_MANAGER_PASSWORD=
CANARY_AGENT_EMAIL=
CANARY_AGENT_PASSWORD=

# GitHub (opcional — necessário para análise de PR no qa-executor)
GH_TOKEN=

# Base de conhecimento local
KB_PATH=

# Jira (opcional — usado pelo argos-predict para buscar tickets)
JIRA_TOKEN=

# K6 Monitor — token de longa duração para o monitor de performance
K6_MONITOR_TOKEN=
K6_ACCOUNT_UUID=

# Sentry (self-hosted) — necessário para análise de erros reais de produção no argos-predict
SENTRY_HOST=https://sentry.poli.digital
SENTRY_ORG=poli
SENTRY_AUTH_TOKEN=

# Anthropic API — necessário para scripts/generate-scenarios.js
# Gere em: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Jira — necessário para scripts/generate-scenarios.js
JIRA_EMAIL=
JIRA_API_TOKEN=

# OpenCode API
OPENCODE_API_KEY=
OPENCODE_API_BASE=https://api.opencode.com/v1

# Modelo padrão do QA
QA_DEFAULT_MODEL=
